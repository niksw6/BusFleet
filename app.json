{
  "expo": {
    "name": "FleetDataApp",
    "slug": "fleetdataapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0066CC"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fleetdata.app"
    },
    "android": {
      "package": "com.fleetdata.app",
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ]
    },
    "plugins": [
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "e1109e0f-e950-4d5d-b765-b431b3638bca"
      }
    },
    "owner": "nikyinform"
  }
}
